function enable_proxy() {
  if [[ $# -eq 0 ]]; then
    echo "usage:"
    echo "enable_proxy host:prot"
  else
    export ALL_PROXY=http://$1
    export HTTP_PROXY=http://$1
    export HTTPS_PROXY=http://$1
  fi
}

